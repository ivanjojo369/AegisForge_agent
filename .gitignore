# =========================
# Secrets / local env files
# =========================
.env
.env.*
!.env.example
*.key
*.pem
*.pfx
*.p12
*.crt
secrets/
**/secrets/

# =========================
# Python caches / artifacts
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# =========================
# Packaging / build outputs
# =========================
*.egg-info/
build/
dist/
pip-wheel-metadata/
*.whl

# =========================
# Test / coverage caches
# =========================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover

# Type checkers / linters
.mypy_cache/
.pyright/
.ruff_cache/

# ======================
# Notebooks / large local datasets
# ======================
.ipynb_checkpoints/
*.ipynb
datasets/

# =========================
# OS / editor files
# =========================
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# =========================
# UV / lock / temporary
# =========================
# Keep uv.lock tracked if you use it.
# uv.lock
*.tmp
*.temp
*.swp

# =========================
# Project-specific outputs
# =========================
results/
output/
outputs/
artifacts/
logs/
tmp/
temp/
cache/
data/cache/

# Agent/eval run dumps
**/test_results/
**/run_results/
**/runs/
**/provenance/*.json
**/provenance/*.csv

# Local logs
*.log

# Local databases/caches are ignored by default...
*.sqlite
*.sqlite3
*.db

# =========================
# Docker backups / local extras
# =========================
**/.dockerignore.backup
phaseB/

# =========================
# AegisForge Unified Purple Agent benchmark data
# =========================
# ...but these benchmark files must be tracked and included in Docker builds.
!data/
!data/**
!data/aegisforge_unified_purple_agent.db
!data/unified_purple_agent/
!data/unified_purple_agent/**
!data/unified_purple_agent/manifest.json
