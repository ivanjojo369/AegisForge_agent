# =========================
# Secrets / local env files
# =========================
.env
.env.*
!.env.example
*.key
*.pem
*.pfx
*.p12
*.crt
secrets/
**/secrets/

# =========================
# Python caches / artifacts
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# =========================
# Packaging / build outputs
# =========================
*.egg-info/
build/
dist/
pip-wheel-metadata/
*.whl

# =========================
# Test / coverage caches
# =========================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.log

# Type checkers / linters
.mypy_cache/
.pyright/
.ruff_cache/

# =========================
# Jupyter / notebooks
# =========================
.ipynb_checkpoints/

# =========================
# OS / editor files
# =========================
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/

