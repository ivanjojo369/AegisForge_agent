# uv.lock
*.tmp
*.temp
*.swp

# =========================
# Project-specific outputs
# =========================
results/
output/
outputs/
artifacts/
logs/
tmp/
temp/

# Agent/eval run dumps (common naming)
**/test_results/
**/run_results/
**/runs/
**/provenance/*.json
**/provenance/*.csv

# If your tooling produces local databases or caches
*.sqlite
*.db
data/cache/
cache/

