# syntax=docker/dockerfile:1.7

ARG PYTHON_VERSION=3.11
FROM python:${PYTHON_VERSION}-slim

LABEL org.opencontainers.image.title="AegisForge Adapter Template"
LABEL org.opencontainers.image.description="Reusable Docker template for AegisForge adapter services"
LABEL org.opencontainers.image.licenses="MIT"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    HOST=0.0.0.0 \
    PORT=8000 \
    AEGISFORGE_PUBLIC_URL=http://127.0.0.1:8000 \
    APP_MODULE=server.app:app

WORKDIR /app

# Minimal system dependencies:
# - curl: used by HEALTHCHECK
# - build-essential: useful if a Python dependency needs compilation
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better Docker layer caching
COPY requirements.txt ./requirements.txt

# Install Python dependencies
RUN python -m pip install --upgrade pip setuptools wheel && \
    python -m pip install --no-cache-dir -r requirements.txt uvicorn

# Copy the remaining adapter source
COPY . .

# Run as non-root user
RUN useradd --create-home --shell /bin/bash appuser && \
    chown -R appuser:appuser /app

USER appuser

EXPOSE 8000

# The service is expected to answer /health
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=5 \
  CMD sh -c 'curl -fsS "http://127.0.0.1:${PORT}/health" >/dev/null || exit 1'

# Change APP_MODULE if your ASGI app lives elsewhere
CMD ["sh", "-c", "uvicorn ${APP_MODULE} --host ${HOST} --port ${PORT}"]
