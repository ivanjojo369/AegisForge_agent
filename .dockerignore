# IMPORTANT:
# Do NOT ignore data/. Dockerfile uses:
#   COPY data ./data
# The unified purple benchmark database must be present in the Docker build context.
!data/
!data/**
!data/aegisforge_unified_purple_agent.db
!data/unified_purple_agent/
!data/unified_purple_agent/**
