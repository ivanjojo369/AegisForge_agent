{
  // MAizeBargAIn AgentBeats manifest for AegisForge.
  // Amber v0 accepts manifest_version ^0.1.0. Keep this file small and
  // evaluator-specific: the participant role for this benchmark is `challenger`.
  // No secrets are hardcoded here; Amber injects config at runtime.
  "manifest_version": "0.1.0",

  metadata: {
    name: "AegisForge MAizeBargAIn Challenger",
    display_name: "AegisForge MAizeBargAIn Challenger",
    description: "AegisForge NCP negotiation adapter for the MAizeBargAIn AgentBeats evaluator.",
    agent: "AegisForge NCP Purple",
    mode: "maizebargain_challenger",
    benchmark: "MAizeBargAIn AgentBeats",
    scenario_family: "maizebargain-agentbeats",
    track: "maizebargain",
    repository: "https://github.com/ivanjojo369/AegisForge_agent",

    // The MAizeBargAIn runner names the participant container `challenger`
    // and exposes participant secrets under AMBER_CONFIG_CHALLENGER_*.
    participant_roles: ["challenger"],

    selected_opponent_tracks: [
      "maizebargain"
    ]
  },

  program: {
    image: "ghcr.io/ivanjojo369/aegisforge_agent:latest",
    entrypoint: "python -u -m aegisforge.runner --host 0.0.0.0 --port 8001",
    env: {
      PYTHONUNBUFFERED: "1",

      // Evaluator-specific routing. The agent.py MAizeBargAIn path handles
      // proposal parsing and emits compact JSON allocations such as:
      // {"allocation_self":[...]}.
      AEGISFORGE_TRACK: "maizebargain",
      AEGISFORGE_BENCHMARK: "maizebargain-agentbeats",
      AEGISFORGE_ADAPTER: "maizebargain",
      AEGISFORGE_SELECTED_OPPONENT_MODE: "1",
      AEGISFORGE_ENABLE_MAIZEBARGAIN: "1",
      AEGISFORGE_MAIZEBARGAIN_MODE: "1",
      AEGISFORGE_OUTPUT_PROTOCOL: "maizebargain_proposal",
      AGENT_OUTPUT_PROTOCOL: "maizebargain_proposal",

      // Shared OpenAI runtime. Amber injects this from the challenger config.
      OPENAI_API_KEY: "${config.openai_api_key}",
      OPENAI_BASE_URL: "https://api.openai.com/v1",
      OPENAI_MODEL: "gpt-4.1",

      // Keep diagnostics local/off by default.
      AEGISFORGE_DEBUG_ARTIFACTS: "0",
      AEGISFORGE_TRACE_ARTIFACTS: "0"
    },
    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 8001 }
      ]
    }
  },

  config_schema: {
    type: "object",
    properties: {
      openai_api_key: {
        type: "string",
        secret: true,
        description: "OpenAI API key injected by AgentBeats/Amber for the challenger participant."
      }
    },
    required: ["openai_api_key"],
    additionalProperties: false
  },

  slots: {},

  provides: {
    a2a: {
      kind: "a2a",
      endpoint: "a2a_endpoint"
    }
  },

  exports: {
    a2a: "a2a"
  }
}
