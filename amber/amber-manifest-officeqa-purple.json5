{
  manifest_version: "0.1.0",

  metadata: {
    name: "AegisForge Build-it Purple",
    display_name: "AegisForge Build-it Purple",
    description: "AegisForge NCP Purple adapter for AgentBeats build_what_i_mean evaluation with exact [BUILD];Color,x,y,z output protocol.",
    agent: "AegisForge NCP Purple",
    mode: "purple_benchmark",
    benchmark: "AgentX-AgentBeats Phase 2 Sprint 4",
    scenario_family: "build_what_i_mean",
    track: "build_what_i_mean",
    repository: "https://github.com/ivanjojo369/AegisForge_agent"
  },

  program: {
    image: "ghcr.io/ivanjojo369/aegisforge_agent:latest",
    entrypoint: "python -u -m aegisforge.runner --host 0.0.0.0 --port 8001",
    env: {
      PYTHONUNBUFFERED: "1",

      // Critical: this must be set on the PURPLE agent container, not only on the green agent.
      AGENT_QA_MODE: "build_it",
      AEGISFORGE_OUTPUT_PROTOCOL: "build_it",
      AGENT_OUTPUT_PROTOCOL: "build_it",
      BUILD_PROTOCOL: "build_it",
      BUILDER_AGENT_MODE: "build_it",

      // Track metadata used by AegisForge internals and traces.
      AEGISFORGE_TRACK: "build_what_i_mean",
      AEGISFORGE_BENCHMARK: "build_what_i_mean",
      AEGISFORGE_ADAPTER: "build_it",

      // Keep extra visible output disabled for strict AgentBeats transcript validation.
      AEGISFORGE_DEBUG_ARTIFACTS: "0",
      AEGISFORGE_TRACE_ARTIFACTS: "0"
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8001 }
      ]
    }
  },

  config_schema: {
    type: "object",
    properties: {},
    required: [],
    additionalProperties: false
  },

  slots: {},

  provides: {
    a2a: {
      kind: "a2a",
      endpoint: "endpoint"
    }
  },

  exports: {
    a2a: "a2a"
  }
}
