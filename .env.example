# Core runtime
HOST=0.0.0.0
PORT=8000
AGENT_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# Public URL used in the advertised Agent Card
AEGISFORGE_PUBLIC_URL=http://127.0.0.1:8000

# Agent identity
AEGISFORGE_AGENT_ID=aegisforge
AEGISFORGE_AGENT_NAME=AegisForge
AEGISFORGE_AGENT_VERSION=0.1.0
AEGISFORGE_AGENT_DESCRIPTION=Submission-ready A2A purple agent runtime for AgentBeats-compatible evaluations.

# Behavior flags
AEGISFORGE_ENABLE_OPENENV=false
AEGISFORGE_ENABLE_TAU2=false
AEGISFORGE_ENABLE_SECURITY=false

# Health / service behavior
HEALTH_PATH=/health
AGENT_CARD_PATH=/.well-known/agent-card.json

# Optional build / release metadata
AEGISFORGE_GIT_SHA=dev
AEGISFORGE_IMAGE_REF=local/aegisforge:dev
AEGISFORGE_TRACK=purple
